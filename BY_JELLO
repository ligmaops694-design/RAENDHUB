-- [[ SISTEM MANAJEMEN TAB & TOMBOL ]] --
local GUI_System = {
    Tabs = {},
    ActiveTab = nil
}

-- FUNGSI UTAMA: AddButton
function AddButton(NamaTab, NamaTombol, InfoButton, Callback)
    -- 1. Buat Tab jika belum ada
    if not GUI_System.Tabs[NamaTab] then
        -- Buat Tombol di Sidebar
        local TabBtn = Instance.new("TextButton")
        TabBtn.Size = UDim2.new(1, 0, 0, 30)
        TabBtn.BackgroundColor3 = Theme.TabBG
        TabBtn.BackgroundTransparency = 0.2
        TabBtn.Text = " " .. NamaTab
        TabBtn.TextColor3 = Theme.TextDim
        TabBtn.Font = Enum.Font.GothamBold
        TabBtn.TextSize = 12
        TabBtn.TextXAlignment = Enum.TextXAlignment.Left
        TabBtn.Parent = Sidebar
        Instance.new("UICorner", TabBtn).CornerRadius = UDim.new(0, 6)

        -- Buat Halaman Scroll untuk Tab ini
        local TabPage = Instance.new("ScrollingFrame")
        TabPage.Size = UDim2.new(1, 0, 1, 0)
        TabPage.BackgroundTransparency = 1
        TabPage.ScrollBarThickness = 2
        TabPage.Visible = false
        TabPage.Parent = ContentContainer
        local PageLayout = Instance.new("UIListLayout", TabPage)
        PageLayout.Padding = UDim.new(0, 6)

        GUI_System.Tabs[NamaTab] = { Button = TabBtn, Page = TabPage, Count = 0 }

        -- Logika klik Tab
        TabBtn.MouseButton1Click:Connect(function()
            for name, data in pairs(GUI_System.Tabs) do
                data.Page.Visible = false
                data.Button.TextColor3 = Theme.TextDim
                if data.Button:FindFirstChild("UIStroke") then data.Button.UIStroke:Destroy() end
            end
            TabPage.Visible = true
            TabBtn.TextColor3 = Theme.NeonCyan
            CreateStroke(TabBtn, Theme.NeonCyan, 1.5)
            GUI_System.ActiveTab = NamaTab
        end)

        -- Auto-buka tab pertama yang dibuat
        if not GUI_System.ActiveTab then
            TabBtn.TextColor3 = Theme.NeonCyan
            CreateStroke(TabBtn, Theme.NeonCyan, 1.5)
            TabPage.Visible = true
            GUI_System.ActiveTab = NamaTab
        end
        Sidebar.CanvasSize = UDim2.new(0, 0, 0, #Sidebar:GetChildren() * 35)
    end

    local CurrentTab = GUI_System.Tabs[NamaTab]
    CurrentTab.Count = CurrentTab.Count + 1

    -- 2. Buat Baris Tombol Script
    local RowFrame = Instance.new("Frame")
    RowFrame.Size = UDim2.new(1, -10, 0, 35)
    RowFrame.BackgroundColor3 = Theme.ItemBG
    RowFrame.BackgroundTransparency = 0.2
    RowFrame.Parent = CurrentTab.Page
    Instance.new("UICorner", RowFrame).CornerRadius = UDim.new(0, 6)

    -- Tombol Eksekusi (Kiri - Memenuhi layar)
    local ExecuteBtn = Instance.new("TextButton")
    ExecuteBtn.Size = UDim2.new(1, -45, 1, 0) -- Sisakan 45px di kanan untuk tombol Info
    ExecuteBtn.BackgroundTransparency = 1
    ExecuteBtn.Text = "  " .. NamaTombol
    ExecuteBtn.TextColor3 = Theme.TextWhite
    ExecuteBtn.Font = Enum.Font.GothamSemibold
    ExecuteBtn.TextSize = 12
    ExecuteBtn.TextXAlignment = Enum.TextXAlignment.Left
    ExecuteBtn.Parent = RowFrame

    -- Efek hover neon saat ditekan
    ExecuteBtn.MouseButton1Click:Connect(function()
        if Callback then Callback() end
        -- Animasi klik kecil
        local str = CreateStroke(RowFrame, Theme.NeonPink, 2)
        task.delay(0.2, function() str:Destroy() end)
    end)

    -- Tombol Info (Kanan - Tanda '?')
    local InfoBtn = Instance.new("TextButton")
    InfoBtn.Size = UDim2.new(0, 35, 0, 25)
    InfoBtn.Position = UDim2.new(1, -40, 0, 5)
    InfoBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 55)
    InfoBtn.Text = "?"
    InfoBtn.TextColor3 = Theme.NeonCyan
    InfoBtn.Font = Enum.Font.GothamBold
    InfoBtn.TextSize = 14
    InfoBtn.Parent = RowFrame
    Instance.new("UICorner", InfoBtn).CornerRadius = UDim.new(0, 6)

    InfoBtn.MouseButton1Click:Connect(function()
        InfoTitle.Text = NamaTombol
        InfoTextLabel.Text = InfoButton
        InfoModal.Visible = true
    end)

    CurrentTab.Page.CanvasSize = UDim2.new(0, 0, 0, CurrentTab.Count * 41)
end

